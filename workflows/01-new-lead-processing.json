      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2900, 600],
      "credentials": { "telegramApi": { "id": "zQbslAZbcF6pqKFh", "name": "Telegram account" } },
      "parameters": {
        "resource": "message", "operation": "sendMessage",
        "chatId": "={{ $('Load Config').first().json.junior_chat_id }}",
        "text": "={{ $json.telegramText }}",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": { "rows": [ { "row": { "buttons": [
          { "text": "🟢 Взять", "additionalFields": { "callback_data": "={{ 'lead_' + $json.row_number + '_taken' }}" } },
          { "text": "⚙️ В работе", "additionalFields": { "callback_data": "={{ 'lead_' + $json.row_number + '_in_progress' }}" } },
          { "text": "✅ Завершено", "additionalFields": { "callback_data": "={{ 'lead_' + $json.row_number + '_done' }}" } }
        ] } } ] },
        "additionalFields": { "appendAttribution": false, "parse_mode": "Markdown" }
      }
    },
    {
      "id": "node-write",
      "name": "Write Telegram IDs",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [3150, 500],
      "credentials": { "googleSheetsOAuth2Api": { "id": "vPYba8prk7sfff5g", "name": "Google Sheets account" } },
      "parameters": {
        "resource": "sheet", "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "1cNcXDPgsVdgmtrnBr6NLNJsyEO3Zhrt5eHvcmJqPpAk", "cachedResultName": "Lead Automation Sheets" },
        "sheetName": { "__rl": true, "mode": "name", "value": "leads", "cachedResultName": "leads" },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["row_number"],
          "value": {
            "row_number": "={{ $('Check Duplicate').first().json.row_number }}",
            "telegram_message_id": "={{ $json.result.message_id }}",
            "telegram_chat_id": "={{ $('Format Message').first().json.routed_to === 'senior' ? $('Load Config').first().json.senior_chat_id : $('Load Config').first().json.junior_chat_id }}",
            "status": "new",
            "created_at": "={{ new Date().toISOString() }}",
            "updated_at": "={{ new Date().toISOString() }}",
            "score": "={{ $('Parse AI Response').first().json.score }}",
            "category": "={{ $('Parse AI Response').first().json.category }}",
            "reason": "={{ $('Parse AI Response').first().json.reason }}",
            "routed_to": "={{ $('Format Message').first().json.routed_to }}"
          },
          "schema": [
            { "id": "row_number", "type": "number", "display": true, "required": false, "displayName": "row_number", "defaultMatch": true, "canBeUsedToMatch": true },
            { "id": "telegram_message_id", "type": "string", "display": true, "required": false, "displayName": "telegram_message_id", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "telegram_chat_id", "type": "string", "display": true, "required": false, "displayName": "telegram_chat_id", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "status", "type": "string", "display": true, "required": false, "displayName": "status", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "created_at", "type": "string", "display": true, "required": false, "displayName": "created_at", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "updated_at", "type": "string", "display": true, "required": false, "displayName": "updated_at", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "score", "type": "number", "display": true, "required": false, "displayName": "score", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "category", "type": "string", "display": true, "required": false, "displayName": "category", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "reason", "type": "string", "display": true, "required": false, "displayName": "reason", "defaultMatch": false, "canBeUsedToMatch": false },
            { "id": "routed_to", "type": "string", "display": true, "required": false, "displayName": "routed_to", "defaultMatch": false, "canBeUsedToMatch": false }
          ],
          "attemptToConvertTypes": false,
          "convertFieldsToString": false
        },
        "options": {}
      }
    }
  ],
  "connections": {
