  "nodes": [
    {
      "id": "node-trigger",
      "name": "Sheets Trigger",
      "type": "n8n-nodes-base.googleSheetsTrigger",
      "typeVersion": 1,
      "position": [200, 300],
      "credentials": { "googleSheetsTriggerOAuth2Api": { "id": "qEKqA8Kw3WPO0o19", "name": "Google Sheets Trigger account" } },
      "parameters": {
        "documentId": { "__rl": true, "mode": "id", "value": "1cNcXDPgsVdgmtrnBr6NLNJsyEO3Zhrt5eHvcmJqPpAk", "cachedResultName": "Lead Automation Sheets" },
        "sheetName": { "__rl": true, "mode": "id", "value": "589358449", "cachedResultName": "leads" },
