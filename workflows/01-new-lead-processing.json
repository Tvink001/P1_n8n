    "Load Config": { "main": [[{ "node": "Validate Fields", "type": "main", "index": 0 }]] },
    "Validate Fields": { "main": [[{ "node": "Normalize", "type": "main", "index": 0 }]] },
    "Normalize": { "main": [[{ "node": "Get All Rows", "type": "main", "index": 0 }, { "node": "Split Leads", "type": "main", "index": 0 }]] },
